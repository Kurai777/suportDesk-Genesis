# Copie para .env e preencha. NENHUM segredo entra no código (regra inviolável nº 5).

# --- Freshdesk ---
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=
# Token secreto que o webhook do Freshdesk envia no header, validado pelo endpoint.
FRESHDESK_WEBHOOK_SECRET=

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Embeddings (Voyage AI) ---
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# --- Banco vetorial (Postgres + pgvector) ---
# Padrão aponta para o banco local do docker-compose. Em produção, use a URL do Railway.
DATABASE_URL=postgresql://totvs:totvs@localhost:5432/suporte_totvs
# Porta do host para o Postgres do docker-compose. Descomente e ajuste se a 5432 já
# estiver ocupada (lembre de usar a MESMA porta na DATABASE_URL acima).
# DB_PORT=5433
# ⚠️ TESTES: os testes de integração fazem DELETE nas tabelas. NUNCA aponte para o
# banco da aplicação — use um banco DEDICADO (crie 'suporte_totvs_test' e rode o
# db/init.sql nele). Ex.: TEST_DATABASE_URL=postgresql://totvs:totvs@localhost:5433/suporte_totvs_test

# --- WhatsApp (Evolution API v2 no piloto) ---
WHATSAPP_API_URL=
# token da INSTÂNCIA da Evolution (não o token global)
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=
# true = não envia de verdade, só loga (padrão seguro em dev). Produção: false.
WHATSAPP_DRY_RUN=true
WHATSAPP_RESPONSAVEL_DEFAULT=
# Mapa id_do_agente (responder_id) -> telefone, em JSON. Ex.: {"67": "5511999999999"}
RESPONSAVEIS={}
# Grupo do WhatsApp que recebe TODOS os feedbacks (ADR-029). É o JID do grupo na Evolution
# (ex.: 120363018941234567@g.us), NÃO um telefone — descubra com:
#   python -m scripts.lista_grupos_whatsapp
# Preenchido = todo chamado notifica o grupo (ignora RESPONSAVEIS). Vazio = notifica o
# telefone do responsável (modelo antigo).
WHATSAPP_GRUPO_DESTINO=
# Segredo do webhook de ENTRADA do WhatsApp (Evolution -> nós), base do relay de token 2FA
# (ADR-026). Vazio = webhook /webhook/whatsapp rejeita tudo (padrão seguro). Configure na
# Evolution como header `x-webhook-secret` OU inclua `?secret=<valor>` na URL do webhook.
WHATSAPP_WEBHOOK_SECRET=

# --- Busca web (último recurso — só dispara quando a base local não resolve) ---
# false = desligada (padrão). true = consulta os domínios oficiais TOTVS
# (centraldeatendimento.totvs.com e tdn.totvs.com) como última tentativa.
# TRADE-OFF DE LATÊNCIA: a consulta ao vivo custa ~16s (busca + abrir/extrair as páginas),
# mas SÓ na cauda — quando a base local falhou e o chamado ia escalar. No webhook isso roda
# em BACKGROUND (o Freshdesk já recebeu 200), então o usuário final não espera; na interface
# de teste /teste, porém, a espera É sentida (a página fica ~16s em "Processando").
BUSCA_WEB_ATIVA=false

# --- Interface de teste local (ADR-019) ---
# true = habilita GET /teste (painel) e POST /teste/processar para inspecionar o pipeline
# localmente SEM tocar no Freshdesk/WhatsApp. NUNCA deixe true em produção (a tela expõe
# os pares recuperados). Padrão: false.
INTERFACE_TESTE_ATIVA=false

# --- Leitura de imagens dos chamados (visão, ADR-023) ---
# true = chamados novos com print de erro/log em anexo têm o texto legível transcrito e
# concatenado à busca (RAG). Best-effort: falha na imagem não derruba o chamado. Padrão: true.
LEITURA_IMAGENS_ATIVA=true

# --- Portal do Cliente TOTVS (API interna, ADR-026) ---
# false = integração não acionada (padrão). O token de sessão (JWT, login 2FA) é injetado em
# runtime — NUNCA fica no .env. A URL base raramente muda.
PORTAL_TOTVS_ATIVO=false
PORTAL_TOTVS_BASE_URL=https://ti-services.totvs.com.br/customer-portal-backend
# Números autorizados a responder o OTP (2FA) no grupo, em JSON. Vazio [] = qualquer membro do
# grupo pode fornecer o código (o grupo já é a fronteira de confiança). Ex.: ["5511999998888"]
PORTAL_OTP_AUTORIZADOS=[]

# --- Reformulação de query antes do RAG (ADR-024) ---
# true = o Claude reescreve o chamado em INTENÇÃO de busca; a busca vira a UNIÃO do texto
# limpo com a intenção (docs respondem à intenção; chamados, ao texto cru). Custa uma chamada
# Haiku curta por chamado. Best-effort: falha usa o texto limpo. Afeta SÓ a busca, nunca a
# resposta ao cliente. Padrão: true.
REFORMULAR_QUERY_ATIVA=true

# --- Regra de negócio ---
CONFIANCA_MINIMA=alta
# Guardrail de distância (ADR-030): só RESOLVE se o melhor par recuperado estiver a uma
# distância de cosseno <= este valor. Cruza o auto-relato do Claude com um sinal objetivo —
# match distante escala mesmo com "alta" (evita o "caso quase-igual", ex.: #4446). Um bom match
# fica ~0,31; os medíocres a partir de ~0,45. Calibrar com dados; menor = mais rígido.
DISTANCIA_MAXIMA_CONFIAVEL=0.40
# Recorte de AUTO-RESPOSTA (ADR-041): limiar de distância p/ um RESOLVIDO ser candidato a resposta
# automática (Fase 2). Hoje é só MARCADOR (nada é enviado). Default = o guardrail.
LIMIAR_AUTO_RESPOSTA=0.40
# MODO SOMBRA da Fase 2 (ADR-042): true = a nota dos auto-elegíveis avisa que o rascunho SERIA
# enviado automaticamente (mas NÃO é — segue copiloto). Ligue para MEDIR em produção o que a IA
# enviaria vs o que a equipe responde, antes de ligar o envio real. Padrão: false.
MODO_SOMBRA_AUTO=false
